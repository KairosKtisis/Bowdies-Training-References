{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path // .tool_response.filePath // empty' | { read -r f; [ -f \"$f\" ] && touch \"$f\"; } 2>/dev/null || true",
            "statusMessage": "Refreshing live preview..."
          }
        ]
      }
    ]
  }
}
